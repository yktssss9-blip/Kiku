rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /questions/{questionId} {
      // 認証済み（管理者アプリ）は全操作可
      allow read, write: if request.auth != null;
      // 未認証（Webブラウザ）は読み取りと回答更新のみ許可
      allow read: if true;
      allow update: if
        request.auth == null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['answers', 'memberNames']);
    }

    // 通報は作成のみ許可（読み取り・更新・削除は管理者のみ）
    match /reports/{reportId} {
      allow create: if request.auth != null;
    }

    // 他のコレクションは認証必須
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
